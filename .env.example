# Slack Incoming Webhook URLs
# -----------------------------
# 1. https://api.slack.com/apps でアプリを作成
# 2. "Incoming Webhooks" を有効化
# 3. チャンネルごとに Webhook URL を発行
# 4. このファイルを .env としてコピーして値を設定
#    cp .env.example .env
#
# ⚠️  .env は .gitignore に入っています。絶対にコミットしないでください。

# CEO ルーム（確認事項・ブロッカー・ステータスサマリー）
SLACK_WEBHOOK_CEO=<Slack管理画面から取得したWebhook URLを貼り付け>

# 日報チャンネル（日次レポート全文）
SLACK_WEBHOOK_DAILY=<Slack管理画面から取得したWebhook URLを貼り付け>

# 部署別チャンネル（空のままにすると通知スキップ）
SLACK_WEBHOOK_SNS=
SLACK_WEBHOOK_CREATIVE=
SLACK_WEBHOOK_VALIDATOR=
